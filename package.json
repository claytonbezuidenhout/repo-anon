{
  "name": "repo-anon",
  "version": "1.0.0",
  "description": "CLI tool to anonymize/de-anonymize repositories.",
  "main": "bin/repo-anon.js",
  "bin": {
    "repo-anon": "bin/repo-anon.js"
  },
  "scripts": {
    "test": "jest --coverage",
    "lint": "eslint .",
    "start": "node bin/repo-anon.js"
  },
  "jest": {
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "clover",
      "cobertura"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jest": "^30.2.0"
  }
}
